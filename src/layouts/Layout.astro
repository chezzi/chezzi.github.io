---
const { title, description } = Astro.props;
---

<!Doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- KaTeX 样式 -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.10/dist/katex.min.css"
    />

    <style>
      :root {
        --max-width: 900px;
        --bg: #fafaf9;
        --text: #1c1c1c;
        --code-bg: #f0f0f0;
        --border: #e2e2e2;
        --link: #0066cc;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #1a1a1a;
          --text: #eaeaea;
          --code-bg: #2d2d2d;
          --border: #3a3a3a;
          --link: #66b3ff;
        }
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family:
          system-ui,
          -apple-system,
          "Segoe UI",
          "Roboto",
          "Noto Sans",
          sans-serif;
        line-height: 1.7;
        padding: 2rem 1rem;
      }

      .container {
        max-width: var(--max-width);
        margin: 0 auto;
      }

      h1,
      h2,
      h3 {
        margin-top: 1.8em;
        margin-bottom: 0.6em;
        font-weight: 600;
      }

      h1 {
        font-size: 2.4rem;
        border-bottom: 3px solid var(--border);
        padding-bottom: 0.5rem;
      }
      h2 {
        font-size: 1.8rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.4rem;
      }
      h3 {
        font-size: 1.4rem;
      }

      p,
      li {
        margin-bottom: 1rem;
      }

      .theorem,
      .proof {
        background: var(--code-bg);
        border-left: 5px solid var(--link);
        padding: 1.2rem 1.5rem;
        margin: 1.8rem 0;
        border-radius: 0.6rem;
      }

      .proof {
        border-left-color: #2c7a4d;
      }

      code:not(.katex *) {
        background: var(--code-bg);
        padding: 0.2rem 0.5rem;
        border-radius: 4px;
        font-family: "JetBrains Mono", monospace;
      }

      a {
        color: var(--link);
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }

      footer {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        text-align: center;
        font-size: 0.95rem;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <slot />
      <!-- 这里会插入 .mdx 文件的内容 -->
    </div>
  </body>
</html>
